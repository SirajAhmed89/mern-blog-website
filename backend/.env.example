PORT=5000
MONGODB_URI=mongodb://localhost:27017/blog
MONGODB_ATLAS_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/blog
USE_ATLAS=false
JWT_SECRET=replace_with_a_64_char_random_string
JWT_EXPIRE=7d
NODE_ENV=development
CLIENT_URL=http://localhost:5173
API_URL=http://localhost:5000

# Email Configuration
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@email.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=your@email.com
EMAIL_FROM_NAME=Your Blog Platform

# Newsletter Automation Configuration
NEWSLETTER_SEND_WELCOME=true
NEWSLETTER_SEND_POST_NOTIFICATION=true
NEWSLETTER_BATCH_SIZE=50
NEWSLETTER_BATCH_DELAY=1000
